# ── CI / GitHub Actions Secrets ───────────────────────────────────────────────
# These worker vars are NOT needed as GitHub secrets — the Docker images
# receive them at runtime via docker-compose / orchestrator env injection.
# Only SERENADE_API_BASE_URL and Android signing secrets are required in CI.
# See backend/.env-example for the full CI secrets list.

# ── Local Dev ──────────────────────────────────────────────────────────────────
RABBITMQ_URL=amqp://USER:PASS@localhost:5672/
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=YOUR_MINIO_USER
MINIO_SECRET_KEY=YOUR_MINIO_PASS
MINIO_BUCKET=serenade
BACKEND_URL=http://localhost:8080
WORKER_API_KEY=same-value-as-INTERNAL_API_KEY
WHISPER_MODEL=base
ADMIN_HOST=0.0.0.0
TRANSCODER_ADMIN_PORT=8000
SUBTITLER_ADMIN_PORT=8001
