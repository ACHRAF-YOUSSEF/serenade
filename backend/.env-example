# ── CI / GitHub Actions Secrets ───────────────────────────────────────────────
# Add these in: GitHub repo → Settings → Secrets and variables → Actions

# Android APK signing — generate with: keytool -genkey -v -keystore serenade.jks -alias serenade -keyalg RSA -keysize 2048 -validity 10000
# then: base64 -w0 serenade.jks | pbcopy
# KEYSTORE_BASE64=<base64-encoded .jks file>
# KEY_ALIAS=serenade
# STORE_PASSWORD=replace-me
# KEY_PASSWORD=replace-me

# Production API URL injected into Android release build
# SERENADE_API_BASE_URL=https://api.yourdomain.com/

# GITHUB_TOKEN is provided automatically — no setup needed for GHCR image push

# ── Local Dev ──────────────────────────────────────────────────────────────────
POSTGRES_DB=serenade
POSTGRES_USER=replace-me
POSTGRES_PASSWORD=replace-me
POSTGRES_JDBC_URL=jdbc:postgresql://localhost:5432/serenade

REDIS_HOST=localhost
REDIS_PORT=6379

RABBITMQ_HOST=localhost
RABBITMQ_PORT=5672
RABBITMQ_USER=replace-me
RABBITMQ_PASSWORD=replace-me

MINIO_ENDPOINT=http://localhost:9000
MINIO_ACCESS_KEY=replace-me
MINIO_SECRET_KEY=replace-me
MINIO_BUCKET=serenade

# openssl rand -hex 64
JWT_SECRET=replace-me-with-at-least-32-random-chars
INTERNAL_API_KEY=replace-me-with-at-least-32-random-chars
WORKER_API_KEY=same-value-as-internal-api-key-for-workers
